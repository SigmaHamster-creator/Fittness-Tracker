#FUNCTION
    
def create_activity(name, description, time):
    activity = {
        "name" : name,
        "description" : description,
        "time" : time 
    }
    return activity

def display_list(List_Activities):
    for i in List_Activities:
        if i == 0:
            print("No activities yet")
        else:
            print(f"Name: {i["name"]} | Description: {i["description"]} | Time: {i["time"]} Minutes")
     
def add_activity(list, activity):
    list.append(activity)
    return list

def total_time_spent(List_Activities):
    total = 0
    for i in List_Activities:
        total += int(i["time"])
    return total

def remove_activity(list, activity):
    list.remove(activity)
    return list

     
